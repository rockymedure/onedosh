# Copy to .env and add your key. The Dosh agent runs on Claude.
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides
DOSH_MODEL=claude-sonnet-5
PORT=8787

# Card Studio — generative card art (fal.ai). Without it, template drops still work.
FAL_KEY=

# Supabase — persists profiles, contacts and transactions for Dosh's skills.
# Without these, Dosh falls back to an in-memory (non-persistent) context.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
